# ===========================================
# AI Chat Hub - Backend Environment Variables
# ===========================================

# ---- LLM Provider API Keys ----

# Groq API Key - Get from: https://console.groq.com/keys
# Free tier: 30 requests/minute, 14,400 requests/day
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenRouter API Key - Get from: https://openrouter.ai/keys
# Free models available, paid models start at $0.0001/1K tokens
OPENROUTER_API_KEY=sk-or-your_openrouter_api_key_here

# ---- Search API ----

# Serper API Key (for web_search tool) - Get from: https://serper.dev/api-key
# Free tier: 2,500 queries
SERPER_API_KEY=your_serper_api_key_here

# ---- Authentication ----

# JWT Secret - Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_32_chars

# Encryption key for API keys storage - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=your_encryption_key_here_64_hex_chars

# ---- Server ----

PORT=3001
NODE_ENV=development

# Frontend URL for CORS (your GitHub Pages URL)
# FRONTEND_URL=https://podshoevbunyod16-sketch.github.io

# ---- Database ----

DATABASE_URL="file:./dev.db"
